{
  "version": 1,
  "purpose": "Machine-readable execution map for the TFG reproducibility pipeline.",
  "pipeline_steps": [
    {
      "order": 1,
      "phase": "ingenieria_dato_base",
      "source_type": "notebook",
      "source": "notebooks/notebook_1_ing_dato.ipynb",
      "command_hint": "jupyter nbconvert --to notebook --execute --inplace notebooks/notebook_1_ing_dato.ipynb",
      "primary_outputs": [
        "DATA/PROCESSED/dataset_cv_municipios.csv"
      ],
      "validation_tests": [
        "tests.test_engineering_outputs.EngineeringOutputsTest.test_daily_dataset_contract"
      ],
      "role": "Builds the daily municipal ERA5-Land base for 2019-2024."
    },
    {
      "order": 2,
      "phase": "ingenieria_dato_fuentes_complementarias",
      "source_type": "notebook",
      "source": "notebooks/notebook_2_ing_fuentes_complementarias.ipynb",
