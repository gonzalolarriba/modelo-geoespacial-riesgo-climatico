      "primary_outputs": [
        "DATA/PROCESSED/dataset_cv_municipios_analisis_municipal.csv",
        "output/analisis/auditoria_variables_score.csv",
        "output/analisis/manifest_artefactos_analisis.csv",
        "output/analisis/puente_analisis_modelado.csv"
      ],
      "validation_tests": [
        "tests.test_engineering_outputs.EngineeringOutputsTest.test_analysis_and_modeling_outputs_contract"
      ],
      "role": "Aggregates to municipal scale, builds exploratory scores and exports analysis artifacts."
    },
    {
      "order": 4,
      "phase": "modelado_segmentacion",
      "source_type": "notebook",
      "source": "notebooks/notebook_4_modelado_segmentacion.ipynb",
      "command_hint": "jupyter nbconvert --to notebook --execute --inplace notebooks/notebook_4_modelado_segmentacion.ipynb",
      "primary_outputs": [
        "DATA/PROCESSED/dataset_cv_municipios_segmentado.csv",
        "output/modelado/model_feature_catalog.csv",
        "output/modelado/model_feature_exclusions.csv",
        "output/modelado/model_preprocessing_audit.csv",
        "output/modelado/model_comparison.csv",
        "output/modelado/model_selection_summary.csv",
        "output/modelado/rf_score_metrics.csv",
        "output/modelado/manifest_artefactos_modelado.csv",
        "output/modelado/rf_score_feature_importance.csv"
      ],
      "validation_tests": [
        "tests.test_engineering_outputs.EngineeringOutputsTest.test_analysis_and_modeling_outputs_contract"
      ],
      "role": "Segments municipalities with KMeans, contrasts models and explains the score with Random Forest."
    },
    {
      "order": 5,
      "phase": "analisis_negocio",
      "source_type": "script",
      "source": "scripts/an_negocio/build_dana_2024_reference.py",
      "command_hint": "python scripts/an_negocio/build_dana_2024_reference.py",
      "primary_outputs": [
        "DATA/PROCESSED/dana_2024_municipios_afectados_boe.csv"
      ],
      "validation_tests": [
        "tests.test_engineering_outputs.EngineeringOutputsTest.test_dana_2024_reference_and_business_outputs_contract"
      ],
      "role": "Builds the official DANA 2024 BOE reference used as external business contrast."
    },
    {
      "order": 6,
      "phase": "analisis_negocio",
      "source_type": "notebook",
      "source": "notebooks/notebook_5_an_negocio.ipynb",
      "command_hint": "jupyter nbconvert --to notebook --execute --inplace notebooks/notebook_5_an_negocio.ipynb",
      "primary_outputs": [
        "DATA/PROCESSED/dataset_cv_municipios_negocio.csv",
        "output/negocio/manifest_artefactos_negocio.csv",
        "output/negocio/dataset_municipal_negocio.csv",
        "output/negocio/dana_2024_validacion_municipal.csv",
        "output/negocio/auditoria_calidad_negocio.csv",
        "output/negocio/recomendaciones_ejecutivas_negocio.csv",
        "output/negocio/matriz_accion_prioridad.csv",
        "output/negocio/matriz_usos_aseguradores.csv"
      ],
      "validation_tests": [
        "tests.test_engineering_outputs.EngineeringOutputsTest.test_dana_2024_reference_and_business_outputs_contract"
      ],
      "role": "Translates segmentation and scores into business priorities, DANA contrast and final business dataset."
    },
    {
      "order": 7,
      "phase": "visualizacion_interactiva",
      "source_type": "app",
      "source": "apps/marimo_negocio.py",
      "command_hint": "python -m marimo run apps/marimo_negocio.py",
      "primary_outputs": [],
      "validation_tests": [
        "tests.test_engineering_outputs.EngineeringOutputsTest.test_marimo_dashboard_compiles_and_uses_business_dataset"
      ],
      "role": "Interactive dashboard that consumes the final business dataset when available."
    }
  ],
